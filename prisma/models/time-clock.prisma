model TimeClock {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  shiftId String?
  shift   Shift?  @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  clockInAt  DateTime?
  clockOutAt DateTime?

  clockInLat  Float?
  clockInLng  Float?
  clockOutLat Float?
  clockOutLng Float?

  // * set by backend service while clock out
  // * Not used anymore
  totalHours    Float?
  overtimeHours Float?

  isOvertimeAllowed Boolean         @default(false)
  status            TimeClockStatus @default(PENDING)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  requestOverTime RequestOverTime[]
}

enum TimeClockStatus {
  PENDING
  ACTIVE
  COMPLETED
  REJECTED
}

model RequestOverTime {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  timeClockId String
  timeClock   TimeClock @relation(fields: [timeClockId], references: [id], onDelete: Cascade)

  reason String
  status RequestOverTimeStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RequestOverTimeStatus {
  PENDING
  APPROVED
  REJECTED
}

model MissedClockRequest {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  shiftId String?
  shift   Shift?  @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  requestedClockInAt  DateTime?
  requestedClockOutAt DateTime?

  location    String?
  locationLat Float?
  locationLng Float?

  reason String
  status MissedClockStatus @default(PENDING)

  reviewedBy String? // adminId
  reviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MissedClockStatus {
  PENDING
  APPROVED
  REJECTED
}
