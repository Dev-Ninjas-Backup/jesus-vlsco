model User {
  id           String    @id @default(uuid())
  phone        String
  employeeID   String
  email        String
  role         String
  isLogin      Boolean
  lastLoginAt  DateTime?
  otp          Int
  otpExpiresAt DateTime?
  isVerified   Boolean
  pinCode      Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile    Profile?
  educations Education[]
}
