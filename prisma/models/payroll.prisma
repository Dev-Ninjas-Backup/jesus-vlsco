model Payroll {
  id                  String          @id @default(uuid())
  offDay              Weekdays[]      @default([SATURDAY, SUNDAY])
  numberOffDay        Int             @default(2)
  breakTimePerDay     BreakTimePerDay @default(NONE)
  regularPayRate      Int             @default(1)
  regularPayRateType  PayRateType     @default(HOUR)
  overTimePayRate     Int             @default(1)
  overTimePayRateType PayRateType     @default(HOUR)
  timeOff             Int             @default(30)
  unpaidLeave         Int             @default(365)
  casualLeave         Int             @default(2)
  sickLeave           Int             @default(2)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  payrollEntry PayrollEntry[]
}

model PayrollEntry {
  id      String @id @default(uuid())
  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  totalHours    Float
  regularHours  Float
  overtimeHours Float
  amount        Float
  status        PayrollStatus @default(PENDING) // PENDING, APPROVED, REJECTED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PayRateType {
  HOUR
  DAY
  WEEK
  MONTH
}

enum Weekdays {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum BreakTimePerDay {
  NONE
  HALF_HOUR
  ONE_HOUR
  TWO_HOUR
  THREE_HOUR
}

enum PayrollStatus {
  PENDING
  APPROVED
  REJECTED
}
