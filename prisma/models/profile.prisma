model Profile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName   String
  lastName    String
  gender      Gender
  jobTitle    JopTitle
  department  String
  address     String
  country     String
  nationality String
  city        String
  state       String
  dob         DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum JopTitle {
  BACK_END_DEVELOPER
  FRONT_END_DEVELOPER
  FULL_STACK_DEVELOPER
  MOBILE_DEVELOPER
  UI_DEVELOPER
  UX_DEVELOPER
  SEALS_ENGINEER
  DATA_SCIENTIST
  DATA_ANALYST
  DATA_ENGINEER
}
