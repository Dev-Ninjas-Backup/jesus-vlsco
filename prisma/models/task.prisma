model Task {
  id          String     @id @default(uuid())
  projectId   String
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  location    String?
  attachment  String?
  labels      String[]
  status      TaskStatus

  tasksUsers TaskUser[]
  project    Project    @relation(fields: [projectId], references: [id])
}

model TaskUser {
  id     String @id @default(uuid())
  task   Task   @relation(fields: [taskId], references: [id])
  taskId String
  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@unique([taskId, userId])
}

enum TaskStatus {
  DAFT
  OPEN
  DONE
}
